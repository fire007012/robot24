<launch>
    <!-- ============================================================ -->
    <!-- Switches                                                      -->
    <!-- ============================================================ -->
    <arg name="enable_usb_cams"      default="false"/>
    <arg name="enable_paw_camera"    default="true"/>
    <arg name="enable_behind_camera" default="true"/>
    <arg name="enable_thermal"       default="true"/>

    <!-- USB camera device paths -->
    <arg name="forward_cam_dev" default=""/>
    <arg name="back_cam_dev"    default=""/>
    <arg name="hand_cam_dev"    default=""/>
    <arg name="arm_cam_dev"     default=""/>

    <!-- D405 RealSense serial numbers 130322273001 or 260322273334-->
    <arg name="paw_serial"    default="260322273334"/>

    <!-- Astra+ serial number -->
    <arg name="behind_serial" default="219323070286"/>

    <!-- D435i serial number (behind_camera 为 RealSense 时使用) -->
    <arg name="behind_realsense_serial" default="112222070518"/>

    <!-- behind_camera 类型: 通过环境变量或 roslaunch 参数指定 -->
    <!-- 优先级：roslaunch传参 > 环境变量 BEHIND_CAMERA_TYPE > 默认 realsense -->
    <!-- 示例：
         roslaunch vision_pkg vision.launch behind_camera_type:=astra
         export BEHIND_CAMERA_TYPE=astra && roslaunch vision_pkg vision.launch
    -->
    <arg name="behind_camera_type" default="$(optenv BEHIND_CAMERA_TYPE realsense)"/>

    <!-- ========================================================== -->
    <!-- 驱动层：相机启动                                            -->
    <!-- ========================================================== -->

    <!-- 1. USB 摄像头 -->
    <group if="$(arg enable_usb_cams)">
      <node pkg="usb_cam" type="usb_cam_node" name="forward_camera" output="screen">
        <param name="video_device" value="$(arg forward_cam_dev)"/>
        <param name="pixel_format" value="yuyv"/>
        <param name="image_width" value="640"/>
        <param name="image_height" value="480"/>
        <param name="camera_frame_id" value="forward_camera"/>
      </node>

      <node pkg="usb_cam" type="usb_cam_node" name="back_camera" output="screen">
        <param name="video_device" value="$(arg back_cam_dev)"/>
        <param name="pixel_format" value="yuyv"/>
        <param name="image_width" value="640"/>
        <param name="image_height" value="480"/>
        <param name="camera_frame_id" value="back_camera"/>
      </node>

      <node pkg="usb_cam" type="usb_cam_node" name="hand_camera" output="screen">
        <param name="video_device" value="$(arg hand_cam_dev)"/>
        <param name="pixel_format" value="yuyv"/>
        <param name="image_width" value="640"/>
        <param name="image_height" value="480"/>
        <param name="camera_frame_id" value="hand_camera"/>
      </node>

      <node pkg="usb_cam" type="usb_cam_node" name="arm_camera" output="screen">
        <param name="video_device" value="$(arg arm_cam_dev)"/>
        <param name="pixel_format" value="yuyv"/>
        <param name="image_width" value="640"/>
        <param name="image_height" value="480"/>
        <param name="camera_frame_id" value="arm_camera"/>
      </node>
    </group>

    <!-- 2. RealSense D405 (paw_camera) -->
    <group if="$(arg enable_paw_camera)">
      <include file="$(find realsense2_camera)/launch/rs_camera.launch">
        <arg name="serial_no" value="$(arg paw_serial)"/>
        <arg name="camera" value="paw_camera"/>
        <arg name="enable_color" value="true"/>
        <arg name="enable_depth" value="true"/>
        <arg name="enable_infra1" value="false"/>
        <arg name="enable_infra2" value="false"/>
        <arg name="enable_pointcloud" value="true"/>
      </include>
    </group>

    <!-- 3. Behind Camera (Astra+ / RealSense D435i) -->
    <group if="$(arg enable_behind_camera)">
      <!-- 3a. Astra+ -->
      <group if="$(eval arg('behind_camera_type') == 'astra')">
        <include file="$(find orbbec_camera)/launch/astra_adv.launch">
          <arg name="camera_name" value="behind_camera"/>
        </include>
      </group>

      <!-- 3b. RealSense D435i -->
      <group if="$(eval arg('behind_camera_type') == 'realsense')">
        <include file="$(find realsense2_camera)/launch/rs_camera.launch">
          <arg name="serial_no" value="$(arg behind_realsense_serial)"/>
          <arg name="camera" value="behind_camera"/>
          <arg name="enable_color" value="true"/>
          <arg name="enable_depth" value="true"/>
          <arg name="enable_infra1" value="false"/>
          <arg name="enable_infra2" value="false"/>
          <arg name="enable_pointcloud" value="true"/>
        </include>
      </group>
    </group>

    <!-- 4. 热成像 Xtherm T2S+ (thermal_camera) -->
    <group if="$(arg enable_thermal)">
      <include file="$(find thermal_camera)/launch/thermal_camera.launch"/>
    </group>

    <!-- ========================================================== -->
    <!-- 功能层：处理节点                                            -->
    <!-- ========================================================== -->

    <!-- 1. 综合视觉显示 (paw_vision) + 物体位姿估计 (object_pose) -->
    <group if="$(arg enable_paw_camera)">
      <node pkg="vision_pkg" type="vision_display_node" name="paw_vision" output="screen">
        <param name="model_path" value="$(find vision_pkg)/model/best.onnx"/>
        <param name="color_topic" value="/paw_camera/color/image_raw"/>
        <param name="depth_topic" value="/paw_camera/depth/image_rect_raw"/>
        <param name="warning_distance" value="0.5"/>
        <param name="use_rows_ratio" value="0.6"/>
        <param name="use_cuda" value="false"/>
      </node>

      <node pkg="vision_pkg" type="object_pose_node" name="paw_object_pose" output="screen">
        <param name="detection_topic" value="/paw_vision/detections"/>
        <param name="depth_topic" value="/paw_camera/depth/image_rect_raw"/>
        <param name="camera_info_topic" value="/paw_camera/color/camera_info"/>
      </node>
    </group>

    <!-- 2. 综合视觉显示 (behind_vision) -->
    <group if="$(arg enable_behind_camera)">
      <node pkg="vision_pkg" type="vision_display_node" name="behind_vision" output="screen">
        <param name="model_path" value="$(find vision_pkg)/model/best.onnx"/>
        <param name="color_topic" value="/behind_camera/color/image_raw"/>
        <param name="depth_topic" value="/behind_camera/depth/image_raw"/>
        <param name="warning_distance" value="0.5"/>
        <param name="use_rows_ratio" value="0.6"/>
        <param name="use_cuda" value="false"/>
      </node>
    </group>

    <!-- 3. 全景拼接 (panorama) -->
    <node pkg="vision_pkg" type="panorama_node" name="panorama" output="screen">
      <param name="cam1_topic" value="/forward_camera/image_raw"/>
      <param name="cam2_topic" value="/back_camera/image_raw"/>
    </node>

  </launch>
