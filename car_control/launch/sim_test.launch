<launch>
  <arg name="joy_dev" default="/dev/input/js0"/>
  <arg name="use_game_controller" default="false"/>
  <arg name="gazebo_gui" default="true"/>
  <arg name="paused" default="false"/>
  <arg name="world_name" default="worlds/empty.world"/>
  <arg name="pipeline" default="ompl"/>
  <arg name="enable_servo" default="true"/>

  <!-- Gazebo + MoveIt + RViz -->
  <include file="$(find car_moveit_config)/launch/demo_gazebo.launch">
    <arg name="gazebo_gui" value="$(arg gazebo_gui)"/>
    <arg name="paused" value="$(arg paused)"/>
    <arg name="world_name" value="$(arg world_name)"/>
    <arg name="pipeline" value="$(arg pipeline)"/>
    <arg name="enable_servo" value="false"/>
    <arg name="enable_teleop" value="false"/>
  </include>

  <!-- MoveIt Servo -->
  <include if="$(arg enable_servo)" file="$(find car_control)/launch/moveit_servo.launch"/>

  <!-- Joystick + base/gripper + DS4/DS5 teleop -->
  <include file="$(find car_control)/launch/teleop_system.launch">
    <arg name="joy_dev" value="$(arg joy_dev)"/>
    <arg name="use_game_controller" value="$(arg use_game_controller)"/>
  </include>
</launch>
