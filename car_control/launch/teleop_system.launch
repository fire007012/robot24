<launch>
  <arg name="joy_dev" default="/dev/input/event0"/>
  <arg name="use_game_controller" default="true"/>

  <node if="$(arg use_game_controller)" pkg="joy" type="game_controller_node" name="joy">
    <param name="dev" value="$(arg joy_dev)"/>
    <param name="deadzone" value="0.12"/>
    <param name="autorepeat_rate" value="60.0"/>
  </node>

  <node unless="$(arg use_game_controller)" pkg="joy" type="joy_node" name="joy">
    <param name="dev" value="$(arg joy_dev)"/>
    <param name="deadzone" value="0.12"/>
    <param name="autorepeat_rate" value="60.0"/>
    <param name="coalesce_interval" value="0.01"/>
  </node>

  <include file="$(find car_control)/launch/control_nodes.launch"/>

  <node pkg="car_control" type="ds5_teleop_node.py" name="ds5_teleop_node" output="screen">
    <rosparam command="load" file="$(find car_control)/config/control_params.yaml"/>
  </node>
</launch>
