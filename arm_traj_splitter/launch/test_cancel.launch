<launch>
  <!-- 测试 5: 上游 Cancel，验证 preempt 转发 -->

  <node name="fake_pp_arm" pkg="arm_traj_splitter"
        type="fake_pp_arm_server.py" output="screen">
    <param name="behavior" value="succeed"/>
    <param name="exec_time" value="5.0"/>  <!-- 故意设长，便于测试 cancel -->
  </node>

  <node name="fake_canopen_arm" pkg="arm_traj_splitter"
        type="fake_canopen_arm_server.py" output="screen">
    <param name="behavior" value="succeed"/>
    <param name="exec_time" value="5.0"/>  <!-- 故意设长，便于测试 cancel -->
  </node>

  <node name="arm_traj_splitter" pkg="arm_traj_splitter"
        type="arm_traj_splitter_node" output="screen">
    <rosparam file="$(find arm_traj_splitter)/config/splitter.yaml" command="load"/>
  </node>
</launch>
