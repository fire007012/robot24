# goal
uint16 motor_id         # 目标电机 ID
float64 target_position # 目标位置（控制层单位）
float64 target_velocity # 目标速度（控制层单位）
float64 max_duration    # 最大执行时长（秒）
---
# result
bool success
string message          # 失败原因
---
# feedback
float64 current_position # 当前位置信息
float64 current_velocity # 当前速度信息
float64 elapsed_time     # 已运行时长（秒）
