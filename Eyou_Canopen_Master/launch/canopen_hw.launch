<launch>
  <param name="robot_description" textfile="$(find car_urdf)/urdf/car_urdf.urdf"/>

  <!-- 配置文件路径 -->
  <arg name="dcf_path" default="$(find Eyou_Canopen_Master)/config/master.dcf"/>
  <arg name="joints_path" default="$(find Eyou_Canopen_Master)/config/joints.yaml"/>
  <arg name="loop_hz" default="200.0"/>
  <arg name="auto_init" default="false"/>
  <arg name="auto_enable" default="false"/>
  <arg name="auto_release" default="false"/>
  <arg name="use_ip_executor" default="false"/>
  <arg name="ip_executor_action_ns" default="arm_position_controller/follow_joint_trajectory"/>
  <arg name="ip_executor_joint_name" default="shoulder_yaw_joint"/>
  <arg name="ip_executor_max_velocity" default="1.0"/>
  <arg name="ip_executor_max_acceleration" default="2.0"/>
  <arg name="ip_executor_max_jerk" default="10.0"/>
  <arg name="ip_executor_goal_tolerance" default="0.001"/>

  <!-- 加载 controller 参数 -->
  <rosparam file="$(find Eyou_Canopen_Master)/config/ros/controllers.yaml" command="load"/>

  <!-- CANopen 硬件节点 -->
  <node name="canopen_hw_node" pkg="Eyou_Canopen_Master" type="canopen_hw_ros_node" output="screen">
    <param name="dcf_path" value="$(arg dcf_path)"/>
    <param name="joints_path" value="$(arg joints_path)"/>
    <param name="loop_hz" value="$(arg loop_hz)"/>
    <param name="auto_init" value="$(arg auto_init)"/>
    <param name="auto_enable" value="$(arg auto_enable)"/>
    <param name="auto_release" value="$(arg auto_release)"/>
    <param name="use_ip_executor" value="$(arg use_ip_executor)"/>
    <param name="ip_executor_action_ns" value="$(arg ip_executor_action_ns)"/>
    <param name="ip_executor_joint_name" value="$(arg ip_executor_joint_name)"/>
    <param name="ip_executor_max_velocity" value="$(arg ip_executor_max_velocity)"/>
    <param name="ip_executor_max_acceleration" value="$(arg ip_executor_max_acceleration)"/>
    <param name="ip_executor_max_jerk" value="$(arg ip_executor_max_jerk)"/>
    <param name="ip_executor_goal_tolerance" value="$(arg ip_executor_goal_tolerance)"/>
  </node>

  <!-- 启动 controllers: joint_state 始终启动，position 默认启动，velocity 加载但不启动 -->
  <node unless="$(arg use_ip_executor)" name="controller_spawner" pkg="controller_manager" type="spawner"
        args="joint_state_controller arm_position_controller" output="screen"/>
  <node if="$(arg use_ip_executor)" name="controller_spawner_ip" pkg="controller_manager" type="spawner"
        args="joint_state_controller" output="screen"/>

  <node name="controller_spawner_stopped" pkg="controller_manager" type="spawner"
        args="--stopped arm_velocity_controller" output="screen"/>

  <!-- robot_state_publisher（需要 URDF 加载到 robot_description，暂时禁用） -->
  <!-- <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher"/> -->
</launch>
