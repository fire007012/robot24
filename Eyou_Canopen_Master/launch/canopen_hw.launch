<launch>
  <param name="robot_description" textfile="$(find Eyou_Canopen_Master)/urdf/robot.urdf"/>

  <!-- 配置文件路径 -->
  <arg name="dcf_path"    default="$(find Eyou_Canopen_Master)/config/master.dcf"/>
  <arg name="joints_path" default="$(find Eyou_Canopen_Master)/config/joints.yaml"/>
  <arg name="loop_hz"     default="100.0"/>

  <!-- 加载 controller 参数 -->
  <rosparam file="$(find Eyou_Canopen_Master)/config/ros/controllers.yaml" command="load"/>

  <!-- CANopen 硬件节点 -->
  <node name="canopen_hw_node" pkg="Eyou_Canopen_Master" type="canopen_hw_ros_node" output="screen">
    <param name="dcf_path"    value="$(arg dcf_path)"/>
    <param name="joints_path" value="$(arg joints_path)"/>
    <param name="loop_hz"     value="$(arg loop_hz)"/>
  </node>

  <!-- 启动 controllers: joint_state 始终启动，position 默认启动，velocity 加载但不启动 -->
  <node name="controller_spawner" pkg="controller_manager" type="spawner"
        args="joint_state_controller arm_position_controller" output="screen"/>

  <node name="controller_spawner_stopped" pkg="controller_manager" type="spawner"
        args="--stopped arm_velocity_controller" output="screen"/>

  <!-- robot_state_publisher（需要 URDF 加载到 robot_description，暂时禁用） -->
  <!-- <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher"/> -->
</launch>
