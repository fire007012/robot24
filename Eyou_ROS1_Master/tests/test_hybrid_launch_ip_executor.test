<launch>
  <include file="$(find Eyou_ROS1_Master)/launch/hybrid_motor_hw.launch">
    <arg name="use_ip_executor" value="true" />
    <arg name="ip_executor_action_ns" value="/arm_position_controller/follow_joint_trajectory" />
    <arg name="start_controllers" value="joint_state_controller" />
  </include>

  <test test-name="test_hybrid_launch_ip_executor"
        pkg="Eyou_ROS1_Master"
        type="test_hybrid_launch_ip_executor"
        time-limit="60.0" />
</launch>
