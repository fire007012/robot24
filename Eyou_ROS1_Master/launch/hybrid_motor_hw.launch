<!-- hybrid_motor_hw.launch
     统一外观节点：同时托管 can_driver 和 Eyou_Canopen_Master 两套后端 -->
<launch>
  <!-- CANopen 侧配置 -->
  <arg name="canopen_dcf_path"    default="$(find Eyou_Canopen_Master)/config/master.dcf"/>
  <arg name="canopen_joints_path" default="$(find Eyou_Canopen_Master)/config/joints.yaml"/>
  <arg name="robot_urdf"          default="$(find car_urdf)/urdf/car_urdf.urdf"/>
  <arg name="use_robot_description" default="true"/>
  <arg name="use_robot_state_publisher" default="true"/>

  <!-- can_driver 侧配置由 can_driver 包维护 -->
  <arg name="can_driver_config"   default="$(find can_driver)/config/can_driver.yaml"/>

  <!-- ros_controllers（可选，留空则不加载） -->
  <arg name="controllers_file"    default="$(find Eyou_ROS1_Master)/config/controllers_minimal.yaml"/>
  <arg name="spawn_controllers"   default="true"/>
  <arg name="start_controllers"   default="joint_state_controller"/>
  <arg name="stopped_controllers" default=""/>

  <!-- CAN 设备 -->
  <arg name="can_device"          default="can0"/>
  <arg name="loopback"            default="false"/>

  <!-- 控制循环频率 -->
  <arg name="loop_hz"             default="200.0"/>
  <arg name="auto_init"           default="false"/>
  <arg name="auto_enable"         default="false"/>
  <arg name="auto_release"        default="false"/>

  <!-- 加载 can_driver 关节参数到节点私有命名空间 -->
  <rosparam file="$(arg can_driver_config)" command="load"
            ns="hybrid_motor_hw_node"/>

  <!-- 加载 ros_controllers 参数 -->
  <rosparam file="$(arg controllers_file)" command="load"
            if="$(eval controllers_file != '')"/>

  <param if="$(arg use_robot_description)"
         name="robot_description"
         textfile="$(arg robot_urdf)"/>

  <node name="hybrid_motor_hw_node"
        pkg="Eyou_ROS1_Master"
        type="hybrid_motor_hw_node"
        output="screen">
    <param name="canopen_dcf_path"    value="$(arg canopen_dcf_path)"/>
    <param name="canopen_joints_path" value="$(arg canopen_joints_path)"/>
    <param name="can_device"          value="$(arg can_device)"/>
    <param name="loopback"            value="$(arg loopback)"/>
    <param name="loop_hz"             value="$(arg loop_hz)"/>
    <param name="auto_init"           value="$(arg auto_init)"/>
    <param name="auto_enable"         value="$(arg auto_enable)"/>
    <param name="auto_release"        value="$(arg auto_release)"/>
  </node>

  <node if="$(arg use_robot_state_publisher)"
        name="robot_state_publisher"
        pkg="robot_state_publisher"
        type="robot_state_publisher"
        output="screen"/>

  <node if="$(eval spawn_controllers and controllers_file != '' and start_controllers != '')"
        name="hybrid_controller_spawner"
        pkg="controller_manager"
        type="spawner"
        args="$(arg start_controllers)"
        output="screen"/>

  <node if="$(eval spawn_controllers and controllers_file != '' and stopped_controllers != '')"
        name="hybrid_controller_spawner_stopped"
        pkg="controller_manager"
        type="spawner"
        args="--stopped $(arg stopped_controllers)"
        output="screen"/>
</launch>
