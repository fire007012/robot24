<launch>
  <arg name="group_name" default="main_arm" />
  <arg name="reference_frame" default="base_link" />
  <arg name="end_effector_link" default="" />
  <arg name="linear_step" default="0.01" />
  <arg name="angular_step_deg" default="5.0" />
  <arg name="velocity_scaling" default="0.2" />
  <arg name="acceleration_scaling" default="0.2" />
  <arg name="planning_time" default="5.0" />
  <arg name="num_planning_attempts" default="1" />

  <node pkg="robot_bringup" type="keyboard_moveit_server.py" name="keyboard_moveit_server" output="screen">
    <param name="group_name" value="$(arg group_name)" />
    <param name="reference_frame" value="$(arg reference_frame)" />
    <param name="end_effector_link" value="$(arg end_effector_link)" />
    <param name="linear_step" value="$(arg linear_step)" />
    <param name="angular_step_deg" value="$(arg angular_step_deg)" />
    <param name="velocity_scaling" value="$(arg velocity_scaling)" />
    <param name="acceleration_scaling" value="$(arg acceleration_scaling)" />
    <param name="planning_time" value="$(arg planning_time)" />
    <param name="num_planning_attempts" value="$(arg num_planning_attempts)" />
  </node>
</launch>
