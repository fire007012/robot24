<launch>
  <arg name="enable_moveit" default="false"/>
  <arg name="enable_graph_check" default="true"/>
  <arg name="check_timeout_sec" default="30"/>

  <include file="$(find robot_bringup)/launch/full_system.launch">
    <arg name="enable_moveit" value="$(arg enable_moveit)"/>
  </include>

  <node if="$(arg enable_graph_check)"
        name="wait_for_graph"
        pkg="robot_bringup"
        type="wait_for_graph.sh"
        args="$(arg check_timeout_sec)"
        output="screen"
        required="true"/>
</launch>
