<launch>
  <param name="/use_sim_time" value="true" />

  <!-- 加载URDF -->
  <param name="robot_description" command="$(find xacro)/xacro '$(find car_urdf)/urdf/car_urdf.urdf'" />

  <!-- 启动Gazebo -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="paused" value="false"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui" value="true"/>
  </include>

  <!-- 在Gazebo中生成机器人 -->
  <node name="urdf_spawner" pkg="gazebo_ros" type="spawn_model" respawn="false" output="screen"
        args="-urdf -model car_robot -param robot_description -z 0.1"/>

  <!-- 加载控制器参数 -->
  <rosparam file="$(find car_urdf)/config/car_controllers.yaml" command="load"/>

  <!-- 启动控制器 -->
  <node name="controller_spawner" pkg="controller_manager" type="spawner" respawn="false"
        output="screen" ns="/car_urdf"
        args="joint_state_controller
              arm_controller
              gripper_controller
              left_front_arm_controller
              right_front_arm_controller
              left_rear_arm_controller
              right_rear_arm_controller"/>

  <!-- robot_state_publisher：将joint_states转为TF供RViz使用 -->
  <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher">
    <remap from="/joint_states" to="/car_urdf/joint_states" />
  </node>

  <!-- 启动RViz -->
  <node name="rviz" pkg="rviz" type="rviz" />
</launch>
