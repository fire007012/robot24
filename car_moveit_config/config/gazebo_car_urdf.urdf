                <mesh filename="package://car_urdf/meshes/zhuaright.STL" />
            </geometry>
            <material name="mat_auto_17">
                <color rgba="1 1 1 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 -0.008 0.007" rpy="0 0 0" />
            <geometry>
                <box size="0.001 0.0005 0.0025" />
            </geometry>
        </collision>
    </link>
    <!-- 替换原来的 zhua2 joint -->
    <joint name="right_gripper_finger_joint" type="prismatic">
        <origin xyz="0 0.045039 0.1005" rpy="0 0 0" />
        <parent link="handshands_course_part" />
        <child link="zhua2" />
        <axis xyz="0 -1 0" />
        <limit lower="-0.022" upper="0.03" effort="20" velocity="0.2" />
        <dynamics damping="0.2" friction="0.02" />
        <!-- ★ 新增：跟随 zhua1 联动 ★ -->
        <mimic joint="left_gripper_finger_joint" multiplier="1" offset="0" />
    </joint>
    <link name="zhua1">
        <inertial>
            <origin xyz="0.00291027333251825 0.00780526162014254 0.00746574903517194" rpy="0 0 0" />
            <mass value="0.0276512162867833" />
            <inertia ixx="8.62898035063976E-06" ixy="2.73869970431535E-07" ixz="2.05949063188403E-07" iyy="6.6214747321261E-06" iyz="5.13082391394944E-07" izz="6.41734046482247E-06" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://car_urdf/meshes/zhualeft.STL" />
            </geometry>
            <material name="mat_auto_18">
                <color rgba="1 1 1 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 -0.008 0.007" rpy="0 0 0" />
            <geometry>
                <box size="0.001 0.0005 0.0025" />
            </geometry>
        </collision>
    </link>
    <joint name="left_gripper_finger_joint" type="prismatic">
        <origin xyz="0.00016784 -0.045039 0.1005" rpy="0 0 0" />
        <parent link="handshands_course_part" />
        <child link="zhua1" />
        <axis xyz="0 1 0" />
        <limit lower="-0.022" upper="0.03" effort="20" velocity="0.2" />
        <dynamics damping="0.2" friction="0.02" />
    </joint>
    <link name="lidar">
        <inertial>
            <origin xyz="1.59594559789866E-15 -3.33066907387547E-16 -4.44089209850063E-16" rpy="0 0 0" />
            <mass value="0.742920987579563" />
            <inertia ixx="0.000937798449134027" ixy="1.03077101557214E-34" ixz="-4.61708918612271E-19" iyy="0.000937798449134027" iyz="-2.78475796235466E-20" izz="0.0010632127983498" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://car_urdf/meshes/lidar.STL" />
            </geometry>
            <material name="mat_auto_19">
                <color rgba="1 1 1 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://car_urdf/meshes/lidar.STL" />
            </geometry>
        </collision>
    </link>
    <joint name="lidar_joint" type="fixed">
        <origin xyz="-0.1555 0.0010002 0.3007" rpy="0 0 0" />
        <parent link="base_link" />
        <child link="lidar" />
        <axis xyz="0 0 0" />
    </joint>
    <link name="camera">
        <inertial>
            <origin xyz="0.00422507049806123 -0.0032377510365096 -0.00209736042516037" rpy="0 0 3.14159" />
            <mass value="0.0491654266514403" />
            <inertia ixx="2.79392843654149E-05" ixy="-4.34509658882138E-07" ixz="-7.7002490330317E-09" iyy="3.41762421577894E-06" iyz="-2.15842945493236E-09" izz="2.71851885152032E-05" />
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://car_urdf/meshes/camera.STL" />
            </geometry>
            <material name="mat_auto_20">
                <color rgba="1 1 1 1" />
            </material>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0" />
            <geometry>
                <mesh filename="package://car_urdf/meshes/camera.STL" />
            </geometry>
        </collision>
    </link>
    <joint name="camera_joint" type="fixed">
        <origin xyz="-0.254895203624053 0.00376119017118452 0.228826235475407" rpy="0 0 0" />
        <parent link="base_link" />
        <child link="camera" />
        <axis xyz="0 0 0" />
    </joint>
    <!-- 底座相机光学帧：将 ROS 机体坐标系转换为光学坐标系 -->
    <link name="camera_optical_frame" />
    <joint name="camera_optical_joint" type="fixed">
        <origin xyz="0 0 0" rpy="-1.5707963 0 -1.5707963" />
        <parent link="camera" />
        <child link="camera_optical_frame" />
    </joint>
    <!-- ============================================== -->
    <!-- 2. 所有可控关节的 transmission                   -->
    <!-- ============================================== -->
    <transmission name="big_course_trans">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="shoulder_yaw_joint">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
        </joint>
        <actuator name="big_course_motor">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>
    <transmission name="big_pitch_trans">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="shoulder_pitch_joint">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
        </joint>
        <actuator name="big_pitch_motor">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>
    <transmission name="small_pitch_trans">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="elbow_pitch_joint">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
        </joint>
        <actuator name="small_pitch_motor">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>
    <transmission name="hands_pitch_trans">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="wrist_pitch_joint">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
        </joint>
        <actuator name="hands_pitch_motor">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>
    <transmission name="hands_roll_trans">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="wrist_roll_joint">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
        </joint>
        <actuator name="hands_roll_motor">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>
    <transmission name="hands_course_trans">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="wrist_yaw_joint">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
        </joint>
        <actuator name="hands_course_motor">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>
    <transmission name="zhua1_trans">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="left_gripper_finger_joint">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
        </joint>
        <actuator name="zhua1_motor">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>
    <!-- ============================================== -->
    <!-- 3. Gazebo ros_control 插件                      -->
    <!-- ============================================== -->
    <gazebo>
        <plugin name="gazebo_ros_control" filename="libgazebo_ros_control.so">
            <robotNamespace>/</robotNamespace>
            <robotSimType>gazebo_ros_control/DefaultRobotHWSim</robotSimType>
        </plugin>
    </gazebo>
    <!-- ============================================== -->
    <!-- 4. Gazebo mimic 插件（让 zhua2 跟随 zhua1）      -->
    <!-- ============================================== -->
    <gazebo>
        <plugin name="mimic_zhua2" filename="libroboticsgroup_upatras_gazebo_mimic_joint_plugin.so">
            <joint>left_gripper_finger_joint</joint>
            <mimicJoint>right_gripper_finger_joint</mimicJoint>
            <multiplier>1.0</multiplier>
            <offset>0</offset>
            <maxEffort>20.0</maxEffort>
            <robotNamespace>/</robotNamespace>
        </plugin>
    </gazebo>
    <!-- ============================================== -->
    <!--  底座相机 Gazebo 仿真                            -->
    <!-- ============================================== -->
    <gazebo reference="camera">
        <sensor type="camera" name="base_camera">
            <update_rate>30.0</update_rate>
            <camera name="base_cam">
                <horizontal_fov>1.3962634</horizontal_fov>
                <!-- 约80度 -->
                <image>
                    <width>640</width>
                    <height>480</height>
                    <format>R8G8B8</format>
                </image>
                <clip>
                    <near>0.02</near>
                    <far>300</far>
                </clip>
                <noise>
                    <type>gaussian</type>
                    <mean>0.0</mean>
                    <stddev>0.007</stddev>
                </noise>
            </camera>
            <plugin name="base_camera_controller" filename="libgazebo_ros_camera.so">
                <alwaysOn>true</alwaysOn>
                <updateRate>30.0</updateRate>
                <cameraName>base_camera</cameraName>
                <imageTopicName>image_raw</imageTopicName>
                <cameraInfoTopicName>camera_info</cameraInfoTopicName>
                <frameName>camera_optical_frame</frameName>
                <hackBaseline>0.0</hackBaseline>
                <distortionK1>0.0</distortionK1>
                <distortionK2>0.0</distortionK2>
                <distortionK3>0.0</distortionK3>
                <distortionT1>0.0</distortionT1>
                <distortionT2>0.0</distortionT2>
            </plugin>
        </sensor>
    </gazebo>
    <!-- ============================================== -->
    <!--  抓取相机 D435i Gazebo 仿真 (RGB + 深度 + IMU)   -->
    <!-- ============================================== -->
    <!-- RGB 彩色相机 -->
    <gazebo reference="catch_camera">
        <sensor type="camera" name="gripper_d435i_color">
            <update_rate>30.0</update_rate>
            <camera name="gripper_color">
                <horizontal_fov>1.2217</horizontal_fov>
                <!-- D435i 色彩相机 69° FOV -->
                <image>
                    <width>640</width>
                    <height>480</height>
                    <format>R8G8B8</format>
                </image>
                <clip>
                    <near>0.1</near>
                    <far>10.0</far>
                </clip>
                <noise>
                    <type>gaussian</type>
                    <mean>0.0</mean>
                    <stddev>0.007</stddev>
                </noise>
            </camera>
            <plugin name="gripper_color_controller" filename="libgazebo_ros_camera.so">
                <alwaysOn>true</alwaysOn>
                <updateRate>30.0</updateRate>
                <cameraName>gripper_camera/color</cameraName>
                <imageTopicName>image_raw</imageTopicName>
                <cameraInfoTopicName>camera_info</cameraInfoTopicName>
                <frameName>catch_camera_optical_frame</frameName>
                <hackBaseline>0.0</hackBaseline>
            </plugin>
        </sensor>
    </gazebo>
    <!-- 深度相机 -->
    <gazebo reference="catch_camera">
        <sensor type="depth" name="gripper_d435i_depth">
            <update_rate>30.0</update_rate>
            <camera name="gripper_depth">
                <horizontal_fov>1.5184</horizontal_fov>
                <!-- D435i 深度 87° FOV -->
                <image>
                    <width>640</width>
                    <height>480</height>
                    <format>R8G8B8</format>
                </image>
                <clip>
                    <near>0.1</near>
                    <far>10.0</far>
                </clip>
                <noise>
                    <type>gaussian</type>
                    <mean>0.0</mean>
                    <stddev>0.005</stddev>
                </noise>
            </camera>
            <plugin name="gripper_depth_controller" filename="libgazebo_ros_openni_kinect.so">
                <alwaysOn>true</alwaysOn>
                <updateRate>30.0</updateRate>
                <cameraName>gripper_camera/depth</cameraName>
                <imageTopicName>image_raw</imageTopicName>
                <cameraInfoTopicName>camera_info</cameraInfoTopicName>
                <depthImageTopicName>image_raw</depthImageTopicName>
                <depthImageCameraInfoTopicName>camera_info</depthImageCameraInfoTopicName>
                <pointCloudTopicName>points</pointCloudTopicName>
                <frameName>catch_camera_optical_frame</frameName>
                <pointCloudCutoff>0.1</pointCloudCutoff>
                <pointCloudCutoffMax>10.0</pointCloudCutoffMax>
            </plugin>
        </sensor>
    </gazebo>
    <!-- IMU (D435i 内置) -->
    <gazebo reference="catch_camera">
        <sensor type="imu" name="gripper_d435i_imu">
            <update_rate>200.0</update_rate>
            <plugin name="gripper_imu_controller" filename="libgazebo_ros_imu_sensor.so">
                <topicName>gripper_camera/imu</topicName>
                <bodyName>catch_camera</bodyName>
                <updateRateHZ>200.0</updateRateHZ>
                <gaussianNoise>0.01</gaussianNoise>
                <frameName>catch_camera</frameName>
            </plugin>
        </sensor>
    </gazebo>
    <!-- ============================================== -->
    <!--  激光雷达 Gazebo 仿真                            -->
    <!-- ============================================== -->
    <!-- <gazebo reference="lidar">
    <sensor type="ray" name="lidar_sensor">
      <pose>0 0 0 0 0 0</pose>
      <visualize>true</visualize>
      <update_rate>10</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.15</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <plugin name="gazebo_ros_lidar" filename="libgazebo_ros_laser.so">
        <topicName>/scan</topicName>
        <frameName>lidar</frameName>
      </plugin>
    </sensor>
  </gazebo> -->
    <!-- 关闭自碰撞 -->
    <!--
  <gazebo reference="handshands_course_part">
    <selfCollide>false</selfCollide>
  </gazebo>

  <gazebo reference="hands_roll_part">
    <selfCollide>false</selfCollide>
  </gazebo>

  <gazebo reference="hands_pitch_part">
    <selfCollide>false</selfCollide>
  </gazebo>

  <gazebo reference="handshands_course_part"><selfCollide>false</selfCollide></gazebo>
  <gazebo reference="catch_camera"><selfCollide>false</selfCollide></gazebo>
  <gazebo reference="zhua1"><selfCollide>false</selfCollide></gazebo>
  <gazebo reference="zhua2"><selfCollide>false</selfCollide></gazebo>
-->
    <!-- ============================================== -->
    <!-- 四个轮子的 Gazebo 摩擦 & 接触参数                  -->
    <!-- ============================================== -->
    <gazebo reference="left_ahead_wheel">
        <mu1>1.0</mu1>
        <mu2>0.15</mu2>
        <kp>1000000.0</kp>
        <kd>100.0</kd>
        <minDepth>0.002</minDepth>
        <maxVel>1.0</maxVel>
        <fdir1>1 0 0</fdir1>
        <material>Gazebo/DarkGrey</material>
    </gazebo>
    <gazebo reference="left_back_wheel">
        <mu1>1.0</mu1>
        <mu2>0.3</mu2>
        <kp>1000000.0</kp>
        <kd>100.0</kd>
        <minDepth>0.002</minDepth>
        <maxVel>1.0</maxVel>
        <fdir1>1 0 0</fdir1>
        <material>Gazebo/DarkGrey</material>
    </gazebo>
    <gazebo reference="right_ahead_wheel">
        <mu1>1.0</mu1>
        <mu2>0.3</mu2>
        <kp>1000000.0</kp>
        <kd>100.0</kd>
        <minDepth>0.002</minDepth>
        <maxVel>1.0</maxVel>
        <fdir1>1 0 0</fdir1>
        <material>Gazebo/DarkGrey</material>
    </gazebo>
    <gazebo reference="right_back_wheel">
        <mu1>1.0</mu1>
        <mu2>0.3</mu2>
        <kp>1000000.0</kp>
        <kd>100.0</kd>
        <minDepth>0.002</minDepth>
        <maxVel>1.0</maxVel>
        <fdir1>1 0 0</fdir1>
        <material>Gazebo/DarkGrey</material>
    </gazebo>
    <!-- ============================================== -->
    <!--  四个摆臂的 Transmission                         -->
    <!-- ============================================== -->
    <transmission name="left_front_arm_trans">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="left_front_arm_joint">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
        </joint>
        <actuator name="left_front_arm_motor">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>
    <transmission name="right_front_arm_trans">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="right_front_arm_joint">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
        </joint>
        <actuator name="right_front_arm_motor">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>
    <transmission name="left_rear_arm_trans">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="left_rear_arm_joint">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
        </joint>
        <actuator name="left_rear_arm_motor">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>
    <transmission name="right_rear_arm_trans">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="right_rear_arm_joint">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
        </joint>
        <actuator name="right_rear_arm_motor">
            <hardwareInterface>hardware_interface/PositionJointInterface</hardwareInterface>
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>
    <!-- ============================================== -->
    <!-- Publish wheel joints to /joint_states for MoveIt state completeness -->
    <gazebo>
        <plugin name="wheel_joint_state_publisher" filename="libgazebo_ros_joint_state_publisher.so">
            <robotNamespace>/</robotNamespace>
            <updateRate>50.0</updateRate>
            <jointName>left_front_wheel_joint,right_front_wheel_joint,left_rear_wheel_joint,right_rear_wheel_joint</jointName>
            <topicName>/joint_states</topicName>
        </plugin>
    </gazebo>
    <!-- ============================================== -->
    <!-- 四轮差速（Skid-Steer）驱动插件                     -->
    <!-- ============================================== -->
    <gazebo>
        <plugin name="skid_steer_drive_controller" filename="libgazebo_ros_skid_steer_drive.so">
            <updateRate>100.0</updateRate>
            <robotNamespace>/</robotNamespace>
            <leftFrontJoint>left_front_wheel_joint</leftFrontJoint>
            <rightFrontJoint>right_front_wheel_joint</rightFrontJoint>
            <leftRearJoint>left_rear_wheel_joint</leftRearJoint>
            <rightRearJoint>right_rear_wheel_joint</rightRearJoint>
            <wheelSeparation>0.438</wheelSeparation>
            <wheelDiameter>0.058</wheelDiameter>
            <torque>10.0</torque>
            <commandTopic>/car_urdf/cmd_vel</commandTopic>
            <odometryTopic>/car_urdf/odom</odometryTopic>
            <odometryFrame>odom</odometryFrame>
            <robotBaseFrame>base_link_root</robotBaseFrame>
            <broadcastTF>true</broadcastTF>
            <covariance_x>0.001</covariance_x>
            <covariance_y>0.001</covariance_y>
            <covariance_yaw>0.01</covariance_yaw>
        </plugin>
    </gazebo>
    <transmission name="trans_left_front_wheel_joint">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="left_front_wheel_joint">
            <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
        </joint>
        <actuator name="left_front_wheel_joint_motor">
            <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>
    <transmission name="trans_left_rear_wheel_joint">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="left_rear_wheel_joint">
            <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
        </joint>
        <actuator name="left_rear_wheel_joint_motor">
            <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>
    <transmission name="trans_right_front_wheel_joint">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="right_front_wheel_joint">
            <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
        </joint>
        <actuator name="right_front_wheel_joint_motor">
            <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>
    <transmission name="trans_right_rear_wheel_joint">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="right_rear_wheel_joint">
            <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
        </joint>
        <actuator name="right_rear_wheel_joint_motor">
            <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>
    <transmission name="trans_right_gripper_finger_joint">
        <type>transmission_interface/SimpleTransmission</type>
        <joint name="right_gripper_finger_joint">
            <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
        </joint>
        <actuator name="right_gripper_finger_joint_motor">
            <hardwareInterface>hardware_interface/EffortJointInterface</hardwareInterface>
            <mechanicalReduction>1</mechanicalReduction>
        </actuator>
    </transmission>
</robot>
